# ─── Auth (shared login for all users) ───────────────
CLAUDE_HUB_AUTH_USERNAME=admin
CLAUDE_HUB_AUTH_PASSWORD=changeme
CLAUDE_HUB_AUTH_SECRET=replace-with-random-string-run-python-c-import-secrets-print-secrets-token-hex-32

# ─── GitHub ──────────────────────────────────────────
# TWO env vars needed — they serve different purposes:
GH_TOKEN=ghp_your_github_personal_access_token
# ^ Used by: gh CLI directly, tmux session env for Claude Code
# gh CLI auto-detects GH_TOKEN from environment.

# If the backend config also reads a CLAUDE_HUB_ prefixed version
# (check config.py), set it to the same value:
# CLAUDE_HUB_GH_TOKEN=ghp_your_github_personal_access_token
# ^ Used by: backend config (Pydantic Settings), project fallback token
# Check config.py to see which name it actually uses. Set both if unsure.

# ─── TicketAgent (Anthropic API) ─────────────────────
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key
CLAUDE_HUB_AGENT_MODEL=claude-opus-4-6
CLAUDE_HUB_AGENT_ENABLED=true
CLAUDE_HUB_AGENT_BUDGET_PER_TICKET_USD=5.00
CLAUDE_HUB_AGENT_BUDGET_DAILY_USD=50.00
CLAUDE_HUB_AGENT_BUDGET_MONTHLY_USD=500.00

# ─── Limits ──────────────────────────────────────────
CLAUDE_HUB_MAX_SESSIONS=4
CLAUDE_HUB_DISALLOWED_TOOLS=Bash(curl:*),Bash(wget:*),Bash(ssh:*)

# ─── Cloudflare Tunnel (production only) ─────────────
# Get from: Cloudflare Dashboard → Zero Trust → Tunnels → Create
CLOUDFLARE_TUNNEL_TOKEN=eyJhIjoixxxx
