# ─── Backend ─────────────────────────────────────
CLAUDE_HUB_HOST=0.0.0.0
CLAUDE_HUB_PORT=7700
CLAUDE_HUB_REPO_URL=https://github.com/user/repo.git
CLAUDE_HUB_BASE_BRANCH=main
CLAUDE_HUB_MAX_SESSIONS=4
CLAUDE_HUB_CLAUDE_BIN=claude
CLAUDE_HUB_LOG_LEVEL=info
CLAUDE_HUB_DATA_DIR=/tmp/claude-hub-data
CLAUDE_HUB_REDIS_URL=redis://localhost:6379/0
CLAUDE_HUB_MERGED_TTL_DAYS=7
CLAUDE_HUB_DISALLOWED_TOOLS=Bash(curl:*),Bash(wget:*),Bash(ssh:*)

# GitHub auth
GH_TOKEN=ghp_xxxx

# ─── TicketAgent ─────────────────────────────────
CLAUDE_HUB_ANTHROPIC_API_KEY=sk-ant-xxx
CLAUDE_HUB_AGENT_MODEL=claude-sonnet-4-6
CLAUDE_HUB_AGENT_ENABLED=true
CLAUDE_HUB_AGENT_BUDGET_PER_TICKET_USD=5.00
CLAUDE_HUB_AGENT_BUDGET_DAILY_USD=50.00
CLAUDE_HUB_AGENT_BUDGET_MONTHLY_USD=500.00

# ─── Frontend ────────────────────────────────────
VITE_API_BASE_URL=http://localhost:7700
VITE_WS_URL=ws://localhost:7700/ws
VITE_DEFAULT_THEME=system
